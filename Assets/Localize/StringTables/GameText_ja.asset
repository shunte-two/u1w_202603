  m_TableData:
  - m_Id: 1000000000001
    m_Localized: 会話パート
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000002
    m_Localized: 会話テキストが未設定です。
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000003
    m_Localized: 現場の資料はそろった。まずは警察の見立てを整理しよう。
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000004
    m_Localized: 容疑者の行動は不審に見えるが、まだ断定は早い。
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000005
    m_Localized: 次は現場の状況を操作して、矛盾がどこで生まれるかを確かめる。
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000006
    m_Localized: 表面的な推理だけでは、まだ筋が通らない。
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000007
    m_Localized: 次はカードの解釈反転や時系列整理に繋がる操作を差し込める状態になった。
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000008
    m_Localized: 操作パート
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000009
    m_Localized: 仮の操作パートです。調査やカード操作の代わりに、ボタンか Enter キーで進めます。
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000010
    m_Localized: 進行完了
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000011
    m_Localized: 仮シーケンス完了。Restart で会話パートから再確認できます。
    m_Metadata:
      m_Items: []
  references:
    version: 1
